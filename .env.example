# 後台管理密碼
ADMIN_PASSWORD=your-admin-password

# JWT 簽章密鑰（建議用 openssl rand -base64 32 產生）
JWT_SECRET=replace-with-random-secret-string

# SQLite 資料庫路徑
# 開發環境（相對於 prisma/ 目錄）：
DATABASE_URL="file:./dev.db"
# 生產環境（必須使用絕對路徑，standalone 模式不支援相對路徑）：
# DATABASE_URL="file:/var/www/thelonesomeera/prisma/production.db"
