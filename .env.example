# 後台管理密碼
ADMIN_PASSWORD=your-admin-password

# JWT 簽章密鑰（建議用 openssl rand -base64 32 產生）
JWT_SECRET=replace-with-random-secret-string

# OpenRouter API Key（文章生成用）
OPENROUTER_API_KEY=your_openrouter_api_key

# AI 圖片生成 API
AI_IMAGE_API_KEY=your_image_api_key
AI_IMAGE_API_URL=https://api.example.com/generate-image

# SQLite 資料庫路徑
# 開發環境（相對於 prisma/ 目錄）：
DATABASE_URL="file:./dev.db"
# 生產環境（必須使用絕對路徑，standalone 模式不支援相對路徑）：
# DATABASE_URL="file:/var/www/thelonesomeera/prisma/production.db"
