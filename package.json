{
  "name": "thelonesomeera",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prisma:prepare-engine": "node scripts/prepare-prisma-engine.mjs",
    "dev": "npm run prisma:prepare-engine && next dev",
    "build": "npm run prisma:prepare-engine && next build",
    "start": "npm run prisma:prepare-engine && next start",
    "lint": "next lint",
    "dev:androidtest": "node scripts/prepare-androidtest-tooling.mjs && npm --prefix androidtest run dev",
    "build:androidtest": "node scripts/prepare-androidtest-tooling.mjs && npm --prefix androidtest run build",
    "build:cod2": "npm --prefix cod2 run build",
    "build:pulsesync": "npm --prefix pulsesync run build",
    "sync:static": "node scripts/sync-static-apps.mjs",
    "build:standalone": "npm run build:androidtest && npm run build:cod2 && npm run build:pulsesync && npm run sync:static",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "jose": "^5.0.0",
    "lucide-react": "^0.460.0",
    "next": "^14.2.0",
    "openai": "^6.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "turndown": "^7.2.2",
    "typescript": "^5.5.0"
  }
}
